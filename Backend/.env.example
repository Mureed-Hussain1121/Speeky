# --- Database ---
# Default matches docker-compose.yml. Override for your own Postgres instance.
DATABASE_URL=postgresql+psycopg2://speeky:speeky@localhost:5432/speeky_onboarding

# --- JWT / security ---
JWT_SECRET=change-me-in-production-please-use-a-long-random-string
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30

# --- Onboarding token lifetimes ---
EMAIL_VERIFICATION_TTL_HOURS=24
PASSWORD_RESET_TTL_MINUTES=60

# --- Account lockout (ONB-US-01 E-03) ---
MAX_FAILED_LOGINS=5
FAILED_LOGIN_WINDOW_MINUTES=15
ACCOUNT_LOCK_MINUTES=15

# --- Password reset rate limiting (ONB-US-03 E-05) ---
RESET_REQUEST_MAX=3
RESET_REQUEST_WINDOW_MINUTES=15

# --- Account deletion grace period (ONB-US-07 E-05) ---
DELETION_GRACE_DAYS=30

# --- Current privacy policy version (ONB-US-06) ---
CURRENT_POLICY_VERSION=1.0

# --- Frontend origin for CORS + link building ---
FRONTEND_ORIGIN=http://localhost:3000

# --- Dev conveniences ---
# When true, the /dev/outbox endpoint and verification tokens are exposed for local testing.
DEV_MODE=true
